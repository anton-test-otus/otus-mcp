# Скопируйте в .env и при необходимости измените значения.
# Файл .env не коммитится — секреты храните только локально.

# Каталог данных (SQLite, изображения, settings.json)
NOTES_MCP_DATA_DIR=/app/data

# HTTP: веб-UI, REST API и MCP streamable-http
NOTES_MCP_HOST=0.0.0.0
NOTES_MCP_PORT=8080
NOTES_MCP_PUBLIC_URL=http://localhost:8080

# Языки Tesseract по умолчанию (rus, eng, rus+eng)
NOTES_MCP_OCR_LANG=rus+eng

# Опционально: ключ OpenAI для будущего чата в UI (не обязателен для MCP)
# OPENAI_API_KEY=sk-...
